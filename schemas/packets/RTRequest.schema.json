{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/packets/RTRequest.schema.json",
  "title": "RTRequest",
  "type": "object",
  "properties": {
    "$header": {
      "type": "string",
      "const": "RT"
    },
    "animation": {
      "type": "string"
    },
    "judgeId": {
      "type": "number",
      "default": -1
    }
  },
  "required": [
    "$header",
    "animation"
  ],
  "additionalProperties": false,
  "x-receiver": "server"
}
