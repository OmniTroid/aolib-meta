{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/packets/LE.schema.json",
  "title": "LE",
  "type": "object",
  "properties": {
    "$header": {
      "type": "string",
      "const": "LE"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "image": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "description",
          "image"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "$header",
    "evidence"
  ],
  "additionalProperties": false,
  "x-receiver": "client"
}
