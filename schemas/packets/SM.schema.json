{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/packets/SM.schema.json",
  "title": "SM",
  "type": "object",
  "properties": {
    "$header": {
      "type": "string",
      "const": "SM"
    },
    "music_list": {
      "type": "array",
