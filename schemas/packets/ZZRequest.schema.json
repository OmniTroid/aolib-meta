{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/packets/ZZRequest.schema.json",
  "title": "ZZRequest",
  "type": "object",
  "properties": {
    "$header": {
      "type": "string",
      "const": "ZZ"
    },
    "reason": {
      "type": "string"
    },
    "target": {
      "type": "number",
      "default": -1
    }
  },
  "required": [
    "$header",
    "reason"
  ],
  "additionalProperties": false,
  "x-receiver": "server"
}
